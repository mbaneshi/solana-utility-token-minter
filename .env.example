# Solana Configuration
SOLANA_NETWORK=devnet
# Options: devnet, mainnet-beta

# RPC Endpoints
DEVNET_RPC_URL=https://api.devnet.solana.com
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
# For production, consider using private RPC providers:
# - QuickNode: https://www.quicknode.com
# - Helius: https://www.helius.dev
# - Triton: https://triton.one

# Wallet Configuration
# WARNING: Never commit actual private keys!
# Store in secure location (e.g., hardware wallet, HSM)
DEPLOYER_PRIVATE_KEY=
# Base58 encoded private key for deployment wallet

# Token Configuration
TOKEN_MINT_ADDRESS=
# Will be populated after token creation

# Token Specifications
TOKEN_NAME=Platform Utility Token
TOKEN_SYMBOL=PUT
TOKEN_DECIMALS=9
TOTAL_SUPPLY=1000000000
# Total supply in full tokens (before decimals)

# Metadata Configuration
TOKEN_DESCRIPTION=Utility token for XYZ platform ecosystem
TOKEN_LOGO_URL=
# URL to token logo (Arweave/IPFS)
TOKEN_WEBSITE=https://platform.com
TOKEN_TWITTER=https://twitter.com/platform
TOKEN_DISCORD=https://discord.gg/platform
TOKEN_TELEGRAM=https://t.me/platform

# Authority Configuration
MINT_AUTHORITY_ENABLED=true
FREEZE_AUTHORITY_ENABLED=false
# Set to false to revoke authorities after deployment

# Multi-Sig Configuration (Optional)
USE_MULTISIG=false
MULTISIG_ADDRESS=
MULTISIG_THRESHOLD=2
MULTISIG_SIGNERS=
# Comma-separated list of signer public keys

# Storage Configuration
ARWEAVE_WALLET=
# Arweave wallet for permanent storage
IPFS_GATEWAY=https://ipfs.io
NFT_STORAGE_API_KEY=
# Get free API key from https://nft.storage

# Tokenomics
INITIAL_MINT_AMOUNT=400000000
# Initial tokens to mint at creation (40% example)
BURN_PERCENTAGE=50
# Percentage of fees to burn (0-100)

# Monitoring
ENABLE_MONITORING=true
ALERT_WEBHOOK_URL=
# Discord/Slack webhook for alerts

# Admin Interface
ADMIN_PORT=3000
ADMIN_AUTH_SECRET=
# Secret for admin interface authentication
